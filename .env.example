# 宝拓小说环境变量模板（仓库根目录）
# 使用方式：
# 1) 复制为 .env：cp .env.example .env
# 2) 至少修改：SECRET_KEY、OPENAI_API_KEY、ADMIN_DEFAULT_PASSWORD
# 3) 若 DB_PROVIDER=mysql，需确保 MYSQL_PASSWORD 非空

# -------------------- 应用基础 --------------------
APP_PORT=80
SECRET_KEY=please-change-to-a-random-secret
ENVIRONMENT=development
DEBUG=true
LOGGING_LEVEL=INFO
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# -------------------- 数据库 --------------------
# 可选：sqlite / mysql
DB_PROVIDER=sqlite

# SQLite（本地开发推荐）
SQLITE_DB_PATH=storage/arboris.db
# Docker Compose 下可将 SQLite 数据映射到本地目录
SQLITE_STORAGE_SOURCE=./storage

# MySQL（DB_PROVIDER=mysql 时生效）
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=arboris
MYSQL_PASSWORD=ChangeMe_Password123
MYSQL_DATABASE=arboris
# 仅在启用 compose profile mysql 时使用
MYSQL_ROOT_PASSWORD=ChangeMe_RootPassword123

# -------------------- 管理员初始化 --------------------
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=ChangeMe123!
ADMIN_DEFAULT_EMAIL=admin@example.com

# -------------------- LLM --------------------
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o-mini
WRITER_CHAPTER_VERSION_COUNT=2

# -------------------- Embedding / RAG --------------------
EMBEDDING_PROVIDER=openai
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_MODEL_VECTOR_SIZE=3072
OLLAMA_EMBEDDING_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest

VECTOR_DB_URL=file:./storage/rag_vectors.db
VECTOR_DB_AUTH_TOKEN=
VECTOR_TOP_K_CHUNKS=5
VECTOR_TOP_K_SUMMARIES=3
VECTOR_CHUNK_SIZE=480
VECTOR_CHUNK_OVERLAP=120

# -------------------- 注册与邮件 --------------------
ALLOW_USER_REGISTRATION=true
SMTP_SERVER=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=no-reply@example.com
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=宝拓小说

# -------------------- Linux.do OAuth（可选） --------------------
ENABLE_LINUXDO_LOGIN=false
LINUXDO_CLIENT_ID=
LINUXDO_CLIENT_SECRET=
LINUXDO_REDIRECT_URI=https://your-domain.com/api/auth/linuxdo/register
LINUXDO_AUTH_URL=https://connect.linux.do/oauth2/authorize
LINUXDO_TOKEN_URL=https://connect.linux.do/oauth2/token
LINUXDO_USER_INFO_URL=https://connect.linux.do/api/user
